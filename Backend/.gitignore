# =============================
# Dependencies aur package managers
# =============================
# Root level dependencies
node_modules/

# Frontend dependencies
Frontend/node_modules/

# Common npm/yarn/pnpm debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =============================
# Build outputs
# =============================
# Generic build folders
build/
dist/
coverage/

# Frontend build folders
Frontend/build/
Frontend/dist/
Frontend/coverage/

# Vite cache output (agar accidentally ban jaye)
Frontend/.vite/

# =============================
# Environment aur secret files
# =============================
# Root env files
.env
.env.*
!.env.example

# Frontend env files
Frontend/.env
Frontend/.env.*
!Frontend/.env.example

# Backend env files (future ready)
Backend/.env
Backend/.env.*
!Backend/.env.example

# =============================
# Editor / IDE files
# =============================
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace
*.swp
*.swo
*~

# =============================
# OS generated files
# =============================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
Desktop.ini

# =============================
# Logs aur runtime dumps
# =============================
logs/
*.log
*.out
*.err
*.pid
*.pid.lock

# =============================
# Cache aur temp files
# =============================
.cache/
.eslintcache
*.tsbuildinfo
tmp/
temp/

# =============================
# Python (future scripting support)
# =============================
__pycache__/
*.pyc
*.pyo
*.pyd

# =============================
# Archive aur backup files
# =============================
*.zip
*.tar
*.tar.gz
*.rar
*.7z

# =============================
# Local database / test artifacts
# =============================
*.sqlite
*.sqlite3
